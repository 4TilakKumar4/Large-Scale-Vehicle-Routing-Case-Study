def plot_comparison(weeklyOn, weeklyNoon, outPath):
    """Bar chart comparing all Q1/Q2/Q3 scenarios."""
    labels = ["Q1\nVans (ON)", "Q2\nMixed (ON)", "Q2\nMixed (NOON)",
              "Q3\nOpt (ON)",  "Q3\nOpt (NOON)"]
    values = [Q1_MI, Q2_MI, 8374, weeklyOn, weeklyNoon]
    colors = ["#52b788", "#4db8e8", "#1565c0", "#f0a030", "#c77b17"]

    fig, ax = plt.subplots(figsize=(12, 6))
    fig.patch.set_facecolor("#0f1117"); ax.set_facecolor("#0f1117")
    bars = ax.bar(labels, values, color=colors, width=0.5, edgecolor="white", lw=0.6, zorder=3)
    for bar, val in zip(bars, values):
        ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+55,
                f"{val:,.0f}\n({val*52/1e6:.2f}M/yr)",
                ha="center", color="white", fontsize=9, fontweight="bold")
    save = Q1_MI - weeklyOn
    if save > 0:
        ax.text(2.5, (Q1_MI + weeklyOn) / 2,
                f"Schedule saves\n{save:,.0f} mi/wk\n(${save*52*0.5:,.0f}/yr)",
                ha="center", color="#52b788", fontsize=9, fontweight="bold",
                bbox=dict(boxstyle="round,pad=.3", facecolor="#1e2130", edgecolor="#52b788"))
    ax.set_ylim(0, max(values) * 1.3)
    ax.set_ylabel("Weekly Miles", color="white")
    ax.set_title("All Scenarios — Weekly Miles (ON=overnight allowed, NOON=no overnight)",
                 color="white", fontweight="bold", fontsize=11)
    ax.tick_params(colors="white")
    ax.yaxis.grid(True, color="#333", ls="--", zorder=0)
    for sp in ax.spines.values(): sp.set_color("#444")
    plt.tight_layout()
    plt.savefig(outPath, dpi=150, bbox_inches="tight", facecolor="#0f1117")
    plt.close()


def run_variant(orders, zipCoords, zipCity, zipState, allow_overnight, label, prefix):
    """Run full two-phase Q3 for one overnight variant and write all outputs."""
    print(f"\n{'='*60}")
    print(f"  {label}")
    print(f"{'='*60}")

    print(f"\nPhase 1 - K-Means ({N_SEEDS} seeds, volume-weighted)...")
    bestMi = float("inf"); bestMap = None; bestSeed = None

    for seed in range(N_SEEDS):
        zipDayMap   = volume_weighted_kmeans(orders, zipCoords, seed)
        routesByDay = {}
        for day in DAYS:
            dayZips = {z for z, d in zipDayMap.items() if d == day}
            routesByDay[day] = fast_solve_day(
                orders[orders["TOZIP"].isin(dayZips)].copy(), allow_overnight)
        mi   = weekly_miles(routesByDay, allow_overnight)
        sday = [sum(1 for d in zipDayMap.values() if d == day) for day in DAYS]
        print(f"  seed {seed:>2}: {mi:>7,.0f} mi  stores/day={sday}")
        if mi < bestMi:
            bestMi = mi; bestMap = zipDayMap.copy(); bestSeed = seed

    print(f"\n  Best seed {bestSeed}: {bestMi:,.0f} mi/week")

    print(f"\nPhase 2 - Local search (store-day swaps)...")
    t0 = time.time()
    finalMap = local_search(orders, bestMap, allow_overnight)
    print(f"  Done in {time.time()-t0:.1f}s")

    print("  Applying full route improvement to final assignment...")
    finalRoutes = {}
    for day in DAYS:
        dayZips = {z for z, d in finalMap.items() if d == day}
        finalRoutes[day] = solve_day(
            orders[orders["TOZIP"].isin(dayZips)].copy(), allow_overnight)
    finalMiles = weekly_miles(finalRoutes, allow_overnight)

    print_summary(finalRoutes, finalMiles, allow_overnight, label)
    verify_solution(finalRoutes, allow_overnight)

    print(f"\n  Store-day assignment balance:")
    print(f"  {'Day':<6} {'Stores':>6} {'Orders':>7} {'Volume ft3':>12}")
    print(f"  {'─'*6} {'─'*6} {'─'*7} {'─'*12}")
    for day in DAYS:
        stores = sum(1 for d in finalMap.values() if d == day)
        ords   = sum(1 for _, row in orders.iterrows() if finalMap.get(row["TOZIP"]) == day)
        vol    = int(sum(row["CUBE"] for _, row in orders.iterrows()
                         if finalMap.get(row["TOZIP"]) == day))
        print(f"  {day:<6} {stores:>6} {ords:>7} {vol:>12,}")

    os.makedirs(OUTPUT_DIR, exist_ok=True)
    export_csv(finalRoutes, zipCity, zipState, allow_overnight, finalMiles,
               os.path.join(OUTPUT_DIR, f"{prefix}_Routes.csv"))
    build_map(finalRoutes, zipCoords, zipCity, allow_overnight, finalMiles, label,
              os.path.join(OUTPUT_DIR, f"{prefix}_RouteMap.html"))
    print(f"\n  {prefix}_Routes.csv written")
    print(f"  {prefix}_RouteMap.html written")

    return finalMiles


def main():
    print("Loading data...")
    orders, distMatrix, zipCoords, zipCity, zipState = load_inputs()
    global DIST_MATRIX, DIST_ARR, DIST_IDX
    DIST_MATRIX = distMatrix
    zips_list   = list(distMatrix.index)
    DIST_IDX    = {int(z): i for i, z in enumerate(zips_list)}
    DIST_ARR    = distMatrix.values.astype(float)
    print(f"  {len(orders)} orders  {orders['TOZIP'].nunique()} stores  {int(orders['CUBE'].sum()):,} ft3")

    weeklyNoon = run_variant(orders, zipCoords, zipCity, zipState,
                               False, "Q3 - OPTIMISED SCHEDULE (NO OVERNIGHT)", "Q3_NOON")

    save = Q1_MI - weeklyNoon
    print(f"\n{'='*60}")
    print(f"  Q3 no-overnight: {weeklyNoon:>7,.0f} mi/week")
    print(f"  Q1 baseline    : {Q1_MI:>7,.0f} mi/week")
    print(f"  Saves          : {save:>7,.0f} mi/week  (${save*52*0.5:,.0f}/year)")
    print(f"{'='*60}")
    print(f"\n  All outputs written to: {OUTPUT_DIR}")


if __name__ == "__main__":
    main()