"""
q3_no_overnight.py - NHG Q3: Optimised delivery schedule — no overnight routes.

Relaxes the fixed weekday schedule from Q1/Q2. Each store ZIP is reassigned
to the day that minimises total weekly route miles.

  Phase 1 - Volume-weighted K-Means: cluster 123 stores into 5 day-zones.
            Stores weighted by weekly cube so busier stores drive cluster shape.
            Best seed (lowest route miles) is kept.
  Phase 2 - Local search: move each store to a cheaper day.
            Re-solves only the 2 affected days per trial for speed.
            Uses fast CW-only routing during search, full 2-opt/or-opt at end.

No overnight — all routes complete within one shift.

Input:  deliveries.xlsx, distances.xlsx  (same folder as this script)
Output: output/Q3_ON_Routes.csv, output/Q3_NOON_Routes.csv,
        output/Q3_ON_RouteMap.html, output/Q3_NOON_RouteMap.html,
        output/Q3_Viz_Comparison.png
"""

import os
import csv
import time
import json
import warnings
from itertools import combinations

import numpy as np
import pandas as pd
from sklearn.cluster import KMeans
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt

warnings.filterwarnings("ignore")

BASE_DIR   = os.path.dirname(os.path.abspath(__file__))
OUTPUT_DIR = os.path.join(BASE_DIR, "output")

VAN_CAPACITY  = 3200
UNLOAD_RATE   = 0.03    # min per ft3
MIN_TIME      = 30      # unload floor in minutes
DRIVING_SPEED = 40      # mph
WINDOW_OPEN   = 8
WINDOW_CLOSE  = 18
BREAK_TIME    = 10      # overnight rest hours
MAX_DRIVING   = 11
MAX_DUTY      = 14
DEPOT_ZIP     = 1887

DAYS    = ["Mon", "Tue", "Wed", "Thu", "Fri"]
N_SEEDS = 10
Q1_MI   = 7025.0
Q2_MI   = 7909.0

DAY_COLORS = {
    "Mon": "#E63946", "Tue": "#F4A261",
    "Wed": "#2A9D8F", "Thu": "#457B9D", "Fri": "#9B5DE5",
}

DIST_MATRIX = None   # pandas matrix (kept for loading)
DIST_ARR    = None   # numpy array for fast distance lookups
DIST_IDX    = None   # zip -> array index


def load_inputs():
    """Load orders, distance matrix, and store coordinates from Excel."""
    ordersRaw = pd.read_excel(os.path.join(BASE_DIR, "deliveries.xlsx"),
                              sheet_name="OrderTable")
    location  = pd.read_excel(os.path.join(BASE_DIR, "deliveries.xlsx"),
                              sheet_name="LocationTable")
    distRaw   = pd.read_excel(os.path.join(BASE_DIR, "distances.xlsx"),
                              sheet_name="Sheet1")

    orders = ordersRaw[ordersRaw["ORDERID"] != 0].copy()
    orders["CUBE"]    = pd.to_numeric(orders["CUBE"],    errors="coerce")
    orders["TOZIP"]   = pd.to_numeric(orders["TOZIP"],   errors="coerce")
    orders["ORDERID"] = pd.to_numeric(orders["ORDERID"], errors="coerce")
    orders = orders.dropna(subset=["CUBE", "TOZIP"]).copy()
    orders["TOZIP"] = orders["TOZIP"].astype(int)

    location = location.dropna(subset=["ZIPID"]).copy()
    location["ZIP"] = pd.to_numeric(location["ZIP"], errors="coerce").astype(int)
    location = location.rename(columns={"Y": "LAT", "X": "LON"})

    distRaw = distRaw.rename(columns={"Unnamed: 0": "ZIP", "Unnamed: 1": "ZIPID"})
    distRaw = distRaw[distRaw["ZIP"] != "Zip"].copy()
    distRaw["ZIP"]   = pd.to_numeric(distRaw["ZIP"],   errors="coerce")
    distRaw["ZIPID"] = pd.to_numeric(distRaw["ZIPID"], errors="coerce")
    distRaw = distRaw.dropna(subset=["ZIP"]).set_index("ZIP")
    distMx  = distRaw.drop(columns=["ZIPID"]).copy()
    distMx.columns = pd.to_numeric(distMx.columns, errors="coerce")

    zipCoords = {int(r["ZIP"]): (float(r["LAT"]), float(r["LON"]))
                 for _, r in location.iterrows()}
    zipCity   = {int(r["ZIP"]): str(r["CITY"])  for _, r in location.iterrows()}
    zipState  = {int(r["ZIP"]): str(r["STATE"]) for _, r in location.iterrows()}

    return orders, distMx, zipCoords, zipCity, zipState


def get_distance(zip1, zip2):
    return float(DIST_ARR[DIST_IDX[int(zip1)], DIST_IDX[int(zip2)]])


def get_unload_time(cube):
    """Unload hours with 30-minute floor regardless of cube size."""
    return max(MIN_TIME, UNLOAD_RATE * cube) / 60.0


def evaluate_route(routeList, allow_overnight=True):
    """Simulate route and return miles, feasibility flags, and DOT hours."""
    firstZip     = routeList[0]["TOZIP"]
    firstDrive   = get_distance(DEPOT_ZIP, firstZip) / DRIVING_SPEED
    dispatchTime = max(0.0, WINDOW_OPEN - firstDrive)

    currentZip  = DEPOT_ZIP
    currentTime = dispatchTime
    totalMiles  = totalDrive = totalUnload = totalWait = 0.0
    totalCube   = 0
    windowOk    = True
    overnight   = False
    driveShift  = dutyShift = 0.0   # reset after overnight break

    for stop in routeList:
        stopZip   = stop["TOZIP"]
        cube      = stop["CUBE"]
        legMi     = get_distance(currentZip, stopZip)
        drive     = legMi / DRIVING_SPEED
        arrival   = currentTime + drive
        svcStart  = max(arrival, float(WINDOW_OPEN))
        wait      = max(0.0, svcStart - arrival)
        unload    = get_unload_time(cube)
        departure = svcStart + unload

        if driveShift + drive > MAX_DRIVING or dutyShift + drive > MAX_DUTY:
            if not allow_overnight or overnight:
                return {"overall_feasible": False, "capacity_ok": True,
                        "window_ok": True, "dot_ok": False,
                        "total_miles": totalMiles, "total_drive": totalDrive,
                        "total_duty": totalDrive + totalUnload + totalWait,
                        "total_cube": totalCube, "overnight": overnight}
            driveShift = dutyShift = 0.0   # 10-hour break resets DOT counters
            overnight  = True
            svcStart   = max(arrival + BREAK_TIME, WINDOW_OPEN + 24)
            departure  = svcStart + unload

        timeOfDay = svcStart % 24
        endOfSvc  = departure % 24
        dayOk     = (WINDOW_OPEN <= timeOfDay <= WINDOW_CLOSE) and (endOfSvc <= WINDOW_CLOSE)
        windowOk  = windowOk and dayOk

        totalMiles  += legMi;  totalDrive  += drive
        totalUnload += unload; totalWait   += wait
        totalCube   += cube
        driveShift  += drive;  dutyShift   += drive + unload + wait
        currentTime  = departure; currentZip = stopZip

    backMi    = get_distance(currentZip, DEPOT_ZIP)
    backDrive = backMi / DRIVING_SPEED
    if driveShift + backDrive > MAX_DRIVING or dutyShift + backDrive > MAX_DUTY:
        return {"overall_feasible": False, "capacity_ok": True,
                "window_ok": windowOk, "dot_ok": False,
                "total_miles": totalMiles, "total_drive": totalDrive,
                "total_duty": totalDrive + totalUnload + totalWait,
                "total_cube": totalCube, "overnight": overnight}

    totalMiles += backMi; totalDrive += backDrive
    totalDuty   = totalDrive + totalUnload + totalWait
    capOk       = totalCube  <= VAN_CAPACITY
    dotOk       = totalDrive <= MAX_DRIVING and totalDuty <= MAX_DUTY

    return {
        "overall_feasible": bool(capOk and windowOk and dotOk),
        "capacity_ok":      bool(capOk),
        "window_ok":        bool(windowOk),
        "dot_ok":           bool(dotOk),
        "total_miles":      round(totalMiles,  1),
        "total_drive":      round(totalDrive,  3),
        "total_unload":     round(totalUnload, 3),
        "total_duty":       round(totalDuty,   3),
        "total_cube":       int(totalCube),
        "overnight":        overnight,
    }


def compute_savings(ordersDF):
    """CW savings s(i,j) = d(depot,i) + d(depot,j) - d(i,j), descending."""
    recs    = ordersDF.to_dict("records")
    savings = []
    for a, b in combinations(recs, 2):
        s = (get_distance(DEPOT_ZIP, a["TOZIP"])
             + get_distance(DEPOT_ZIP, b["TOZIP"])
             - get_distance(a["TOZIP"], b["TOZIP"]))
        savings.append((s, int(a["ORDERID"]), int(b["ORDERID"])))
    savings.sort(key=lambda x: x[0], reverse=True)
    return savings


def clarke_wright(dayOrders, allow_overnight=True):
    """Parallel CW savings construction — merges routes highest-savings first."""
    recs    = {int(r["ORDERID"]): r for _, r in dayOrders.iterrows()}
    routes  = {oid: [rec] for oid, rec in recs.items()}
    routeOf = {oid: oid for oid in recs}
    headOf  = {oid: oid for oid in recs}
    tailOf  = {oid: oid for oid in recs}

    for s, oi, oj in compute_savings(dayOrders):
        if s <= 0: break
        if oi not in routeOf or oj not in routeOf: continue
        ri = routeOf[oi]; rj = routeOf[oj]
        if ri == rj: continue
        rtI = routes[ri]; rtJ = routes[rj]
        candidates = []
        if tailOf[ri] == oi and headOf[rj] == oj: candidates.append((rtI + rtJ, ri, rj))
        if tailOf[rj] == oj and headOf[ri] == oi: candidates.append((rtJ + rtI, rj, ri))
        if tailOf[ri] == oi and tailOf[rj] == oj: candidates.append((rtI + rtJ[::-1], ri, rj))
        if headOf[ri] == oi and headOf[rj] == oj: candidates.append((rtI[::-1] + rtJ, ri, rj))
        for merged, keep, drop in candidates:
            if evaluate_route(merged, allow_overnight)["overall_feasible"]:
                routes[keep] = merged; del routes[drop]
                headOf[keep] = int(merged[0]["ORDERID"])
                tailOf[keep] = int(merged[-1]["ORDERID"])
                for stop in merged: routeOf[int(stop["ORDERID"])] = keep
                del headOf[drop]; del tailOf[drop]
                break

    return list(routes.values())


def two_opt_route(route, allow_overnight=True):
    """Reverse sub-segments until no improvement in route miles."""
    best = route[:]; bestMiles = evaluate_route(best, allow_overnight)["total_miles"]
    improved = True
    while improved:
        improved = False
        for i in range(len(best) - 1):
            for j in range(i + 2, len(best)):
                trial  = best[:i] + best[i:j+1][::-1] + best[j+1:]
                result = evaluate_route(trial, allow_overnight)
                if result["overall_feasible"] and result["total_miles"] < bestMiles:
                    best, bestMiles, improved = trial, result["total_miles"], True; break
            if improved: break
    return best


def or_opt_route(route, allow_overnight=True):
    """Relocate chains of 1-3 stops within the route."""
    best = route[:]; bestMiles = evaluate_route(best, allow_overnight)["total_miles"]
    improved = True
    while improved:
        improved = False
        for chainLen in [1, 2, 3]:
            for i in range(len(best) - chainLen + 1):
                chain     = best[i:i+chainLen]
                remainder = best[:i] + best[i+chainLen:]
                for j in range(len(remainder) + 1):
                    if j == i: continue
                    trial  = remainder[:j] + chain + remainder[j:]
                    result = evaluate_route(trial, allow_overnight)
                    if result["overall_feasible"] and result["total_miles"] < bestMiles:
                        best, bestMiles, improved = trial, result["total_miles"], True; break
                if improved: break
            if improved: break
    return best


def improve_routes(allRoutes, allow_overnight=True):
    """Apply 2-opt then or-opt to every route in the list."""
    improved = []
    for route in allRoutes:
        if len(route) >= 4: route = two_opt_route(route, allow_overnight)
        if len(route) >= 2: route = or_opt_route(route,  allow_overnight)
        improved.append(route)
    return improved


def solve_day(dayOrders, allow_overnight=True):
    """CW + full improvement — used for final solution quality."""
    if len(dayOrders) == 0: return []
    return improve_routes(clarke_wright(dayOrders, allow_overnight), allow_overnight)


def fast_solve_day(dayOrders, allow_overnight=True):
    """CW only, no improvement — used inside local search for speed."""
    if len(dayOrders) == 0: return []
    return clarke_wright(dayOrders, allow_overnight)


def weekly_miles(routesByDay, allow_overnight=True):
    """Sum total route miles across all days."""
    return sum(evaluate_route(r, allow_overnight)["total_miles"]
               for routes in routesByDay.values() for r in routes)


def volume_weighted_kmeans(orders, zipCoords, seed):
    """
    Cluster 123 stores into 5 day-groups weighted by weekly order volume.
    Busier stores pull cluster centres harder — balances ft3 workload per day.
    """
    zipVol  = orders.groupby("TOZIP")["CUBE"].sum().to_dict()  # ft3 weight per store
    allZips = sorted(zipVol.keys())
    coords  = np.array([zipCoords[z] for z in allZips])
    weights = np.array([zipVol.get(z, 1) for z in allZips], dtype=float)
    weights /= weights.sum()   # normalised so sample_weight works correctly

    km = KMeans(n_clusters=5, init="k-means++", n_init=1,
                random_state=seed, max_iter=300)
    km.fit(coords, sample_weight=weights)
    return {z: DAYS[km.labels_[i]] for i, z in enumerate(allZips)}


def local_search(orders, zipDayMap, allow_overnight=True):
    """
    Move each store to a cheaper day until no single move helps.
    Re-solves only the 2 affected days per trial — not all 5 — for speed.
    Uses fast CW-only routing so each trial is ~0.02s not ~0.5s.
    """
    dayRoutes = {}
    for day in DAYS:
        dayZips = {z for z, d in zipDayMap.items() if d == day}
        dayRoutes[day] = fast_solve_day(
            orders[orders["TOZIP"].isin(dayZips)].copy(), allow_overnight)

    dayMi     = {d: sum(evaluate_route(r, allow_overnight)["total_miles"]
                        for r in dayRoutes[d]) for d in DAYS}
    bestMiles = sum(dayMi.values())
    print(f"    Start: {bestMiles:,.0f} mi")

    for iteration in range(1, 6):    # cap at 5 iterations
        improved = False

        for z in sorted(zipDayMap.keys()):
            currentDay = zipDayMap[z]
            if len(orders[orders["TOZIP"] == z]) == 0:
                continue

            for newDay in DAYS:
                if newDay == currentDay: continue

                zipDayMap[z] = newDay   # tentative move

                srcZips  = {zz for zz, d in zipDayMap.items() if d == currentDay}
                dstZips  = {zz for zz, d in zipDayMap.items() if d == newDay}
                srcRts   = fast_solve_day(orders[orders["TOZIP"].isin(srcZips)].copy(), allow_overnight)
                dstRts   = fast_solve_day(orders[orders["TOZIP"].isin(dstZips)].copy(), allow_overnight)
                srcMi    = sum(evaluate_route(r, allow_overnight)["total_miles"] for r in srcRts)
                dstMi    = sum(evaluate_route(r, allow_overnight)["total_miles"] for r in dstRts)
                delta    = (srcMi + dstMi) - (dayMi[currentDay] + dayMi[newDay])

                if delta < -0.5:   # accept if genuinely reduces miles
                    dayRoutes[currentDay] = srcRts; dayRoutes[newDay] = dstRts
                    dayMi[currentDay]     = srcMi;  dayMi[newDay]     = dstMi
                    bestMiles            += delta
                    improved              = True
                    currentDay            = newDay
                    break
                else:
                    zipDayMap[z] = currentDay   # revert

        print(f"    Iter {iteration}: {bestMiles:,.0f} mi")
        if not improved:
            break

    return zipDayMap


