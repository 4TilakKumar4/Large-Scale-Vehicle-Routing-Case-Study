    print("=" * 60)
    print(f"  {'Day':<6} {'Routes':>6} {'Orders':>7} {'Miles':>9}")
    print(f"  {'─'*6} {'─'*6} {'─'*7} {'─'*9}")
    for day in DAYS:
        nRt = len(routesByDay[day])
        nOr = sum(len(r) for r in routesByDay[day])
        mi  = sum(evaluate_route(r, allow_overnight)["total_miles"]
                  for r in routesByDay[day])
        print(f"  {day:<6} {nRt:>6} {nOr:>7} {mi:>9,.0f}")
    totRt = sum(len(routesByDay[d]) for d in DAYS)
