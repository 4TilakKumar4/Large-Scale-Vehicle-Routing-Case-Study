    print(f"  Annual  : {weeklyMi*52:>10,.0f} mi")
    print(f"  vs Q1   : {weeklyMi - Q1_MI:>+10,.0f} mi/week  ({(weeklyMi-Q1_MI)/Q1_MI*100:+.1f}%)")
    print(f"  vs Q2   : {weeklyMi - Q2_MI:>+10,.0f} mi/week")
    print("=" * 60)


def verify_solution(routesByDay, allow_overnight):
    """Check all 261 orders served and all constraints satisfied."""
    allServed = [int(s["ORDERID"]) for d in DAYS
                 for r in routesByDay[d] for s in r]
    ordersOk = len(allServed) == 261 and len(set(allServed)) == 261
    capOk    = all(evaluate_route(r, allow_overnight)["capacity_ok"]  for d in DAYS for r in routesByDay[d])
    dotOk    = all(evaluate_route(r, allow_overnight)["dot_ok"]       for d in DAYS for r in routesByDay[d])
    winOk    = all(evaluate_route(r, allow_overnight)["window_ok"]    for d in DAYS for r in routesByDay[d])
    feasOk   = all(evaluate_route(r, allow_overnight)["overall_feasible"] for d in DAYS for r in routesByDay[d])
    print(f"\n  Verification:")
    print(f"    261 orders served : {'OK' if ordersOk else 'FAIL'}")
    print(f"    Capacity <= 3200  : {'OK' if capOk    else 'FAIL'}")
    print(f"    DOT limits        : {'OK' if dotOk    else 'FAIL'}")
    print(f"    Window 8am-6pm    : {'OK' if winOk    else 'FAIL'}")
    print(f"    All feasible      : {'OK' if feasOk   else 'FAIL'}")
    return ordersOk and capOk and dotOk and winOk and feasOk


def export_csv(routesByDay, zipCity, zipState, allow_overnight, weeklyMi, outPath):
    """Write one CSV row per route with OID sequence and city labels."""
    def oidSeq(route):
        return "0 -> " + " -> ".join(str(int(s["ORDERID"])) for s in route) + " -> 0"
    def locSeq(route):
        parts = ["0 (DC-Wilmington,MA)"]
        for s in route:
            z = int(s["TOZIP"])
            parts.append(f"{int(s['ORDERID'])} ({zipCity.get(z,'?')}, {zipState.get(z,'?')})")
        parts.append("0 (DC-Wilmington,MA)")
        return " -> ".join(parts)

    rows = []
    for day in DAYS:
        for ri, route in enumerate(routesByDay[day]):
            res  = evaluate_route(route, allow_overnight)
            cube = sum(int(s["CUBE"]) for s in route)
            rows.append({
                "Route": f"{day}_R{ri+1}", "Day": day,
                "Stops": len(route), "Miles": round(res["total_miles"], 1),
                "Cube_ft3": cube, "Capacity_ft3": VAN_CAPACITY,
                "Util_Pct": round(cube / VAN_CAPACITY * 100, 1),
                "Overnight": "Yes" if res["overnight"] else "No",
                "Drive_h": round(res["total_drive"], 2),
                "Duty_h":  round(res["total_duty"],  2),
                "Feasible": res["overall_feasible"],
                "WeeklyMiles": round(weeklyMi, 0),
                "AnnualMiles": round(weeklyMi * 52, 0),
                "Order_IDs": oidSeq(route),
                "Route_Sequence": locSeq(route),
            })
    with open(outPath, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=list(rows[0].keys()))
        w.writeheader(); w.writerows(rows)


